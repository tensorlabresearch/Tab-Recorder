{
  "manifest_version": 3,
  "name": "Tab Recorder",
  "version": "0.1.0",
  "description": "Audio-first tab recorder with highlights and searchable session history.",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "tabCapture",
    "desktopCapture",
    "tabs",
    "storage",
    "identity",
    "offscreen",
    "sidePanel",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://www.googleapis.com/*",
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Tab Recorder",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "oauth2": {
    "client_id": "642161396777-7pa8k0k0l2dmtgug7gjoh7cfds96844f.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  }
}
